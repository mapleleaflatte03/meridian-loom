[runtime]
mode = "embedded"
kernel_path = "/tmp/meridian-kernel"
org_id = "local_foundry"
state_dir = ".loom"

[workers]
python_path = "workers/python"
typescript_path = "workers/typescript"
wasm_dir = "workers/wasm"

[operator]
# Use one of the checked-in operator profiles as a starting point:
#   solo -> minimal ceremony
#   builder -> stronger audit + wasm isolation
#   team -> approvals + parity
#   institution -> microvm + full proof chain
profile = "solo"

[wasm]
# Built-in runtime profile presets are intentionally conservative.
# Adjust these only if the execution surface truly needs them.
profile = "standard"
max_memory_bytes = 67108864
max_table_elements = 10000
max_instances = 10
max_tables = 10
max_memories = 10
fuel_limit = 1000000

[wasm.host]
backend = "preview_only"
component_model = true
allocation = "pooling"
isolation = "in_process"
fuel_metering = true
epoch_deadline_ms = 1000
