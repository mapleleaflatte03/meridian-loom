{
  "schema_version": "meridian.connect.adapter.v1",
  "adapter_id": "webhook-ops-adapter",
  "name": "webhook_ops_adapter",
  "transport": "webhook",
  "action_schema": "meridian.runtime.v1",
  "runtime_contract": "connect_runtime_contract_v2",
  "lifecycle": {
    "enabled": false,
    "state": "init",
    "auth_state": "pending",
    "reconnect_attempts": 0,
    "reconnect_attempts_max": 3
  },
  "fallback": {
    "mode": "local_queue_shadow",
    "active": false
  },
  "transport_profile": {
    "kind": "webhook",
    "method": "POST",
    "content_type": "application/json",
    "inbound_mode": "generic_http_ingress",
    "health_endpoint": "/health"
  }
}

