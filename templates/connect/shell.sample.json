{
  "schema_version": "meridian.connect.adapter.v1",
  "adapter_id": "shell-ops-adapter",
  "name": "shell_ops_adapter",
  "transport": "shell",
  "action_schema": "meridian.runtime.v1",
  "runtime_contract": "connect_runtime_contract_v2",
  "lifecycle": {
    "enabled": false,
    "state": "init",
    "auth_state": "pending",
    "reconnect_attempts": 0,
    "reconnect_attempts_max": 3
  },
  "fallback": {
    "mode": "local_queue_shadow",
    "active": false
  },
  "transport_profile": {
    "kind": "shell",
    "execution_mode": "restricted_executor",
    "sandbox": "filesystem_guarded",
    "health_endpoint": "/health"
  }
}

