+fn constant_time_eq(a: &str, b: &str) -> bool {
+    if a.len() != b.len() {
+        return false;
+    }
+    let mut result = 0;
+    for (byte_a, byte_b) in a.bytes().zip(b.bytes()) {
+        result |= byte_a ^ byte_b;
+    }
+    // Use black_box to prevent the compiler from optimizing out the loop
+    // or short-circuiting it, maintaining constant-time characteristics
+    // for strings of the same length.
+    std::hint::black_box(result) == 0
+}
